<Page x:Class="Pr14.FilmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="900"
      Title="Информация о фильме"
      Background="#E8F5E9"
      DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20" 
                    Margin="0,0,0,20"
                    BorderBrush="#C8E6C9" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" 
                                     ShadowDepth="2" 
                                     Opacity="0.1" 
                                     Direction="270"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" 
                            Height="400" 
                            Width="280" 
                            Background="#E8F5E9" 
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            BorderBrush="#A5D6A7"
                            BorderThickness="1">
                        <Image Source="{Binding CurrentCinema.Image}" 
                               Stretch="Uniform" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               MaxHeight="380"
                               MaxWidth="260"
                               Margin="5"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">
                        <TextBlock Text="{Binding CurrentCinema.Name}" 
                                   FontSize="32" 
                                   FontWeight="SemiBold" 
                                   Foreground="#1B5E20"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#FFF9C4" 
                                    CornerRadius="20" 
                                    Padding="15,8"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="★ " Foreground="#F57C00" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentCinema.Rating, StringFormat={}{0:F1}}" 
                                               Foreground="#F57C00" 
                                               FontSize="18" 
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#2E7D32" 
                                    CornerRadius="20" 
                                    Padding="15,8">
                                <TextBlock Text="{Binding CurrentCinema.AgeRating.Name}" 
                                           Foreground="White" 
                                           FontSize="14" 
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Жанры:" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="#1B5E20"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding CurrentCinema.GenresCinema}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8F5E9" 
                                                CornerRadius="15" 
                                                Padding="10,5"
                                                Margin="0,0,8,5"
                                                BorderBrush="#A5D6A7"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Genres.Name}" 
                                                       Foreground="#1B5E20" 
                                                       FontSize="13"
                                                       FontWeight="Medium"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="О фильме:" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="#1B5E20"
                                       Margin="0,0,0,8"/>
                            <Border Background="#F1F8E9"
                                    CornerRadius="8"
                                    Padding="12">
                                <TextBlock Text="{Binding CurrentCinema.Description}" 
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#2E7D32"
                                           LineHeight="22"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20"
                    BorderBrush="#C8E6C9" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" 
                                     ShadowDepth="2" 
                                     Opacity="0.1" 
                                     Direction="270"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Сеансы" 
                               FontSize="24" 
                               FontWeight="SemiBold" 
                               Foreground="#1B5E20"
                               Margin="0,0,0,20"/>

                    <ListBox x:Name="SessionsListBox" 
                             ItemsSource="{Binding Sessions}"
                             Background="Transparent" 
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="SessionsListBox_SelectionChanged">

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" 
                                        CornerRadius="10" 
                                        Padding="15"
                                        Margin="0,0,0,10"
                                        BorderBrush="#C8E6C9" 
                                        BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Setter Property="BorderBrush" Value="#2E7D32"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,25,0">
                                            <Border Background="#E8F5E9" 
                                                    CornerRadius="8" 
                                                    Padding="8,4">
                                                <TextBlock Text="{Binding DateTime, StringFormat='dd.MM.yyyy'}" 
                                                           FontSize="14" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="#1B5E20"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,25,0">
                                            <Border Background="#FFF9C4" 
                                                    CornerRadius="8" 
                                                    Padding="8,4">
                                                <TextBlock Text="{Binding DateTime, StringFormat='HH:mm'}" 
                                                           FontSize="14" 
                                                           FontWeight="Bold" 
                                                           Foreground="#F57C00"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock Text="Зал №" Foreground="#2E7D32" FontSize="14"/>
                                            <TextBlock Text="{Binding HallNumber}" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="#1B5E20"
                                                       FontSize="14"
                                                       Margin="3,0,15,0"/>

                                            <Border Background="#2E7D32" 
                                                    CornerRadius="12" 
                                                    Padding="8,3">
                                                <TextBlock Text="{Binding RatingName}" 
                                                           Foreground="White" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ChairPrice, StringFormat={}{0} ₽}" 
                                                       FontSize="16" 
                                                       FontWeight="Bold" 
                                                       Foreground="#2E7D32"
                                                       Margin="0,0,5,0"/>
                                            <TextBlock Text="за место" 
                                                       Foreground="#388E3C"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border.ToolTip>
                                        <ToolTip>
                                            <ToolTip.Template>
                                                <ControlTemplate>
                                                    <Border Background="White" 
                                                            BorderBrush="#C8E6C9" 
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <StackPanel Margin="8">
                                                            <TextBlock Text="{Binding RatingName}" 
                                                                       FontWeight="SemiBold" 
                                                                       Foreground="#1B5E20" 
                                                                       Margin="0,0,0,5"/>
                                                            <TextBlock Text="{Binding Description}" 
                                                                       TextWrapping="Wrap" 
                                                                       MaxWidth="200"
                                                                       Foreground="#2E7D32"
                                                                       FontSize="12"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </ToolTip.Template>
                                        </ToolTip>
                                    </Border.ToolTip>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border x:Name="NoSessionsBorder" 
                            Visibility="Collapsed"
                            Background="#F1F8E9" 
                            CornerRadius="10" 
                            Padding="30"
                            Margin="0,10,0,0"
                            BorderBrush="#C8E6C9" 
                            BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🎬" FontSize="48" HorizontalAlignment="Center" Foreground="#2E7D32"/>
                            <TextBlock Text="Нет доступных сеансов" 
                                       FontSize="16" 
                                       Foreground="#1B5E20" 
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"
                                       FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>