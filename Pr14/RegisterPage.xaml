<Page x:Class="Pr14.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Регистрация"
      Background="#E8F5E9">

    <Grid Background="#E8F5E9">
        <Border Width="450" 
                Height="550" 
                Background="White" 
                CornerRadius="15" 
                BorderBrush="#C8E6C9" 
                BorderThickness="1"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                 ShadowDepth="3" 
                                 Opacity="0.15" 
                                 Direction="270"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30">

                    <TextBlock Text="Регистрация" 
                              FontSize="26" 
                              FontWeight="SemiBold" 
                              Foreground="#1B5E20" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,25"/>

                    <TextBlock Text="Имя" 
                              Margin="0,0,0,5" 
                              Foreground="#2E7D32" 
                              FontWeight="Medium"
                              FontSize="13"/>
                    <TextBox x:Name="NameTextBox" 
                            Height="38" 
                            Padding="10" 
                            BorderBrush="#A5D6A7" 
                            BorderThickness="1"
                            Margin="0,0,0,15"
                            FontSize="13"
                            Background="#F9F9F9">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="Логин" 
                              Margin="0,0,0,5" 
                              Foreground="#2E7D32" 
                              FontWeight="Medium"
                              FontSize="13"/>
                    <TextBox x:Name="LoginTextBox" 
                            Height="38" 
                            Padding="10" 
                            BorderBrush="#A5D6A7" 
                            BorderThickness="1"
                            Margin="0,0,0,15"
                            FontSize="13"
                            Background="#F9F9F9">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="Email" 
                              Margin="0,0,0,5" 
                              Foreground="#2E7D32" 
                              FontWeight="Medium"
                              FontSize="13"/>
                    <TextBox x:Name="MailTextBox" 
                            Height="38" 
                            Padding="10" 
                            BorderBrush="#A5D6A7" 
                            BorderThickness="1"
                            Margin="0,0,0,15"
                            FontSize="13"
                            Background="#F9F9F9">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="Пароль" 
                              Margin="0,0,0,5" 
                              Foreground="#2E7D32" 
                              FontWeight="Medium"
                              FontSize="13"/>
                    <PasswordBox x:Name="PasswordBox" 
                               Height="38" 
                               Padding="10" 
                               BorderBrush="#A5D6A7" 
                               BorderThickness="1"
                               Margin="0,0,0,15"
                               FontSize="13"
                               Background="#F9F9F9">
                        <PasswordBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>

                    <TextBlock Text="Подтверждение пароля" 
                              Margin="0,0,0,5" 
                              Foreground="#2E7D32" 
                              FontWeight="Medium"
                              FontSize="13"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" 
                               Height="38" 
                               Padding="10" 
                               BorderBrush="#A5D6A7" 
                               BorderThickness="1"
                               Margin="0,0,0,25"
                               FontSize="13"
                               Background="#F9F9F9">
                        <PasswordBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>

                    <Button x:Name="RegisterButton" 
                           Content="Зарегистрироваться" 
                           Height="42" 
                           Background="#2E7D32" 
                           Foreground="White" 
                           FontWeight="SemiBold" 
                           FontSize="15"
                           BorderThickness="0"
                           Margin="0,0,0,20"
                           Cursor="Hand"
                           Click="RegisterButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Уже есть аккаунт? " 
                                  Foreground="#666666"
                                  FontSize="13"
                                  VerticalAlignment="Center"/>
                        <Button x:Name="LoginLinkButton" 
                               Content="Войти" 
                               Background="Transparent" 
                               BorderThickness="0"
                               Foreground="#2E7D32"
                               Cursor="Hand"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Click="LoginLinkButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="0"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#388E3C"/>
                                            <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <Border Height="1" 
                            Background="#E8F5E9" 
                            Margin="0,20,0,0"
                            CornerRadius="1"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>