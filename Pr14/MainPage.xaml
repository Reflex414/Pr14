<Page x:Class="Pr14.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="Главная страница"
      Background="#E8F5E9">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" 
                                  ShadowDepth="2" 
                                  Opacity="0.1" 
                                  Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal" 
                           VerticalAlignment="Center">
                    <TextBlock Text="Сортировать:" 
                              VerticalAlignment="Center" 
                              Margin="0,0,15,0" 
                              FontWeight="SemiBold"
                              FontSize="14"
                              Foreground="#1B5E20"/>

                    <RadioButton x:Name="NameSortRadio" 
                                Content="По названию" 
                                FontSize="13"
                                Foreground="#1B5E20"
                                Margin="0,0,15,0"
                                Checked="NameSort_Checked"/>

                    <RadioButton x:Name="RatingSortRadio" 
                                Content="По рейтингу" 
                                FontSize="13"
                                Foreground="#1B5E20"
                                Checked="RatingSort_Checked"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">

                    <TextBox x:Name="SearchTextBox" 
                             Width="200"
                             Height="32"
                             Padding="8,5"
                             Margin="0,0,10,0"
                             FontSize="13"
                             TextChanged="SearchTextBox_TextChanged"
                             ToolTip="Введите название фильма"
                             BorderBrush="#C8E6C9"
                             BorderThickness="1"/>

                    <Button x:Name="ClearButton" 
                            Content="Сбросить" 
                            Click="ClearButton_Click" 
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="12,5"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Height="32">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ListBox x:Name="CinemaListBox" 
                 Grid.Row="1" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="Transparent"
                 BorderThickness="0"
                 SelectionChanged="CinemaListBox_SelectionChanged">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#C8E6C9" 
                            BorderThickness="1" 
                            Margin="8" 
                            Padding="12" 
                            Background="White"
                            CornerRadius="10"
                            Width="220">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" 
                                             Opacity="0.1" 
                                             ShadowDepth="2"/>
                        </Border.Effect>

                        <StackPanel>

                            <Border Height="140" 
                                    Margin="0,0,0,10" 
                                    Background="#E8F5E9" 
                                    CornerRadius="5">
                                <Image Source="{Binding Image}" 
                                       Stretch="Uniform" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       MaxHeight="130"
                                       MaxWidth="190"/>
                            </Border>

                            <TextBlock Text="{Binding Name}" 
                                       FontWeight="Bold" 
                                       FontSize="15"
                                       TextAlignment="Center" 
                                       Margin="0,5"
                                       TextWrapping="Wrap"
                                       MaxHeight="40"
                                       Foreground="#1B5E20"/>

                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,5">
                                <TextBlock Text="Рейтинг: " 
                                           Foreground="#666666"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding Rating, StringFormat={}{0:F1}}" 
                                           Foreground="#F57C00" 
                                           FontWeight="Bold"
                                           FontSize="13"/>
                                <TextBlock Text="/10" 
                                           Foreground="#666666"
                                           FontSize="11"
                                           VerticalAlignment="Bottom"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,3">
                                <TextBlock Text="С: " 
                                           Foreground="#666666"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding DateStart, StringFormat='dd.MM.yyyy'}" 
                                           Foreground="#388E3C"
                                           FontSize="12"/>
                            </StackPanel>

                            <Border Background="#2E7D32" 
                                    CornerRadius="3" 
                                    Padding="6,2"
                                    Margin="5"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AgeRating.Name}" 
                                           Foreground="White" 
                                           FontWeight="Bold"
                                           FontSize="10"/>
                            </Border>

                            <ItemsControl ItemsSource="{Binding GenresCinema}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" 
                                                   HorizontalAlignment="Center"
                                                   Margin="0,3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Genres.Name}" 
                                                   Margin="3,0"
                                                   FontSize="11"
                                                   Foreground="#1B5E20"
                                                   FontStyle="Italic"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>