<Page x:Class="Pr14.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Личный кабинет"
      Background="#E8F5E9"
      DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="15" 
                Padding="25" 
                Margin="0,0,0,20"
                BorderBrush="#C8E6C9" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" 
                                 ShadowDepth="2" 
                                 Opacity="0.1" 
                                 Direction="270"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding Client.Name}" 
                           FontSize="28" 
                           FontWeight="SemiBold" 
                           Foreground="#1B5E20"
                           Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Email: " Foreground="#2E7D32" FontSize="16"/>
                    <TextBlock Text="{Binding Client.Mail}" 
                               Foreground="#388E3C" 
                               FontSize="16"
                               FontWeight="Medium"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="15" 
                Padding="20"
                Margin="0,0,0,20"
                BorderBrush="#C8E6C9" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" 
                                 ShadowDepth="2" 
                                 Opacity="0.1" 
                                 Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Мои билеты" 
                               FontSize="24" 
                               FontWeight="SemiBold" 
                               Foreground="#1B5E20"/>
                    <TextBlock Text="{Binding Tickets.Count, StringFormat=' ({0})'}" 
                               FontSize="20" 
                               Foreground="#388E3C"
                               Margin="5,0,0,0"
                               FontWeight="Medium"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Сортировать:" 
                               Foreground="#2E7D32" 
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               FontSize="14"/>
                    <ComboBox x:Name="SortComboBox" 
                              Width="150"
                              Height="32"
                              SelectedIndex="0"
                              BorderBrush="#A5D6A7"
                              Foreground="#1B5E20"
                              SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="По дате (новые)"/>
                        <ComboBoxItem Content="По дате (старые)"/>
                        <ComboBoxItem Content="По фильму"/>
                        <ComboBoxItem Content="По цене (возраст)"/>
                        <ComboBoxItem Content="По цене (убывание)"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="15" 
                Padding="20"
                BorderBrush="#C8E6C9" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" 
                                 ShadowDepth="2" 
                                 Opacity="0.1" 
                                 Direction="270"/>
            </Border.Effect>

            <Grid>

                <ListBox x:Name="TicketsListBox" 
                         ItemsSource="{Binding Tickets}"
                         Background="Transparent" 
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Visibility="Visible">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F8F9FA" 
                                    CornerRadius="12" 
                                    Padding="20"
                                    Margin="0,0,0,15"
                                    BorderBrush="#C8E6C9" 
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F8F9FA"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0" 
                                            Grid.RowSpan="3"
                                            Grid.Column="0"
                                            Width="80" 
                                            Height="100" 
                                            Background="#E8F5E9" 
                                            CornerRadius="8"
                                            Margin="0,0,20,0"
                                            BorderBrush="#A5D6A7"
                                            BorderThickness="1">
                                        <Image Source="{Binding CinemaHall.Cinema.Image}" 
                                               Stretch="Uniform" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"
                                               MaxWidth="70"
                                               MaxHeight="90"/>
                                    </Border>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding CinemaHall.Cinema.Name}" 
                                                   FontSize="18" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="#1B5E20"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="Дата: " Foreground="#2E7D32"/>
                                            <TextBlock Text="{Binding CinemaHall.DateTime, StringFormat='dd.MM.yyyy'}" 
                                                       Foreground="#1B5E20"
                                                       Margin="0,0,15,0"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="Время: " Foreground="#2E7D32"/>
                                            <TextBlock Text="{Binding CinemaHall.DateTime, StringFormat='HH:mm'}" 
                                                       Foreground="#F57C00"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Зал №: " Foreground="#2E7D32"/>
                                            <TextBlock Text="{Binding CinemaHall.Hall.HallNumber}" 
                                                       Foreground="#1B5E20"
                                                       Margin="0,0,15,0"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="Тип зала: " Foreground="#2E7D32"/>
                                            <Border Background="#E8F5E9"
                                                    CornerRadius="12"
                                                    Padding="6,2"
                                                    BorderBrush="#A5D6A7"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding CinemaHall.Hall.RatingHall.RatingName}" 
                                                           Foreground="#1B5E20"
                                                           FontWeight="Medium"
                                                           FontSize="12"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="Место: " Foreground="#2E7D32"/>
                                            <Border Background="#E8F5E9"
                                                    CornerRadius="8"
                                                    Padding="8,2">
                                                <TextBlock Text="{Binding Chair.NumberChair}" 
                                                           Foreground="#1B5E20"
                                                           FontWeight="Bold"
                                                           FontSize="14"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Цена: " Foreground="#2E7D32"/>
                                            <TextBlock Text="{Binding Price, StringFormat={}{0} ₽}" 
                                                       Foreground="#2E7D32"
                                                       FontSize="18"
                                                       FontWeight="Bold"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="Куплен: " Foreground="#2E7D32"/>
                                            <TextBlock Text="{Binding PurchaseDate, StringFormat='dd.MM.yyyy HH:mm'}" 
                                                       Foreground="#388E3C"
                                                       FontSize="11"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Row="0" 
                                            Grid.RowSpan="3"
                                            Grid.Column="2" 
                                            Width="50" 
                                            Height="50" 
                                            Background="#2E7D32" 
                                            CornerRadius="25"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="🎫" 
                                                   FontSize="25" 
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="NoTicketsBorder" 
                        Visibility="Collapsed"
                        Background="#F1F8E9" 
                        CornerRadius="12" 
                        Padding="40"
                        Margin="0,10,0,0"
                        BorderBrush="#C8E6C9" 
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" 
                                         Opacity="0.1" 
                                         ShadowDepth="2"/>
                    </Border.Effect>

                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🎫" 
                                   FontSize="64" 
                                   HorizontalAlignment="Center" 
                                   Foreground="#2E7D32"/>
                        <TextBlock Text="У вас пока нет билетов" 
                                   FontSize="18" 
                                   Foreground="#1B5E20" 
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"
                                   FontWeight="Medium"/>
                        <Button Content="Купить билеты" 
                                Width="150"
                                Height="40"
                                Margin="0,20,0,0"
                                Background="#2E7D32"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="15,8"
                                Cursor="Hand"
                                Click="BuyTicketsButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#388E3C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>