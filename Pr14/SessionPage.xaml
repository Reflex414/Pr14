<Page x:Class="Pr14.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Выбор мест"
      Background="#E8F5E9">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20" 
                    Margin="0,0,0,20"
                    BorderBrush="#C8E6C9" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" 
                                     ShadowDepth="2" 
                                     Opacity="0.1" 
                                     Direction="270"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,30,0">
                        <TextBlock Text="Фильм:" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#1B5E20"
                                   Margin="0,0,10,0"/>
                        <TextBlock x:Name="FilmNameTextBlock" 
                                   FontSize="16" 
                                   Foreground="#2E7D32"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                            <TextBlock Text="Дата:" 
                                       FontWeight="SemiBold" 
                                       Foreground="#1B5E20"
                                       Margin="0,0,5,0"/>
                            <TextBlock x:Name="DateTextBlock" 
                                       Foreground="#2E7D32"
                                       FontWeight="Medium"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                            <TextBlock Text="Время:" 
                                       FontWeight="SemiBold" 
                                       Foreground="#1B5E20"
                                       Margin="0,0,5,0"/>
                            <TextBlock x:Name="TimeTextBlock" 
                                       Foreground="#F57C00"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Зал №:" 
                                       FontWeight="SemiBold" 
                                       Foreground="#1B5E20"
                                       Margin="0,0,5,0"/>
                            <TextBlock x:Name="HallNumberTextBlock" 
                                       Foreground="#2E7D32"
                                       FontWeight="Medium"/>
                            <TextBlock Text=" (" Foreground="#2E7D32"/>
                            <TextBlock x:Name="RatingNameTextBlock" 
                                       Foreground="#388E3C"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text=")" Foreground="#2E7D32"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Цена:" 
                                   FontWeight="SemiBold" 
                                   Foreground="#1B5E20"
                                   Margin="0,0,5,0"/>
                        <TextBlock x:Name="PriceTextBlock" 
                                   Foreground="#2E7D32"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="15"
                    Margin="0,0,0,20"
                    BorderBrush="#C8E6C9" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" 
                                     ShadowDepth="2" 
                                     Opacity="0.1" 
                                     Direction="270"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                            <Border Width="20" 
                                    Height="20" 
                                    Background="White" 
                                    BorderBrush="#A5D6A7" 
                                    BorderThickness="2" 
                                    CornerRadius="5" 
                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Свободно" 
                                       Foreground="#2E7D32" 
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                            <Border Width="20" 
                                    Height="20" 
                                    Background="#2E7D32" 
                                    CornerRadius="5" 
                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Выбрано" 
                                       Foreground="#2E7D32" 
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="20" 
                                    Height="20" 
                                    Background="#E0E0E0" 
                                    CornerRadius="5" 
                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Занято" 
                                       Foreground="#2E7D32" 
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2" 
                            x:Name="ClearButton"
                            Content="Убрать все выбранные места" 
                            Click="ClearButton_Click"
                            Background="#2E7D32" 
                            Foreground="White"
                            BorderThickness="0"
                            Padding="15,8"
                            Cursor="Hand"
                            FontSize="13">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="2" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="25"
                    Margin="0,0,0,20"
                    BorderBrush="#C8E6C9" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" 
                                     ShadowDepth="2" 
                                     Opacity="0.1" 
                                     Direction="270"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="ЭКРАН" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="#2E7D32"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <Border Height="6" 
                            Margin="0,0,0,30"
                            Width="450"
                            HorizontalAlignment="Center"
                            CornerRadius="3">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A5D6A7" Offset="0"/>
                                <GradientStop Color="#2E7D32" Offset="0.5"/>
                                <GradientStop Color="#A5D6A7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <ListBox x:Name="SeatsByRow" 
                             Background="Transparent" 
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">

                                    <Border Background="#E8F5E9"
                                            CornerRadius="5"
                                            Padding="5"
                                            Width="35"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding RowNumber}" 
                                                   FontWeight="Bold" 
                                                   Foreground="#1B5E20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Seats}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="42" 
                                                        Height="42"
                                                        Margin="6,0"
                                                        Padding="0"
                                                        BorderThickness="2"
                                                        Click="SeatButton_Click"
                                                        Tag="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Name="border"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="8">
                                                                            <TextBlock Text="{Binding SeatNumber}" 
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{TemplateBinding Foreground}"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>

                                                            <!-- Базовые стили в зависимости от состояния -->
                                                            <Style.Triggers>
                                                                <!-- Занятое место (серый) -->
                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                    <Setter Property="Background" Value="#E0E0E0"/>
                                                                    <Setter Property="BorderBrush" Value="#BDBDBD"/>
                                                                    <Setter Property="Foreground" Value="#9E9E9E"/>
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                                </DataTrigger>

                                                                <!-- Свободное место (белый) -->
                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                                    <Setter Property="Background" Value="White"/>
                                                                    <Setter Property="BorderBrush" Value="#A5D6A7"/>
                                                                    <Setter Property="Foreground" Value="#1B5E20"/>
                                                                    <Setter Property="IsEnabled" Value="True"/>
                                                                </DataTrigger>

                                                                <!-- Выбранное место (зеленый) - переопределяет свободное -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsAvailable}" Value="True"/>
                                                                        <Condition Binding="{Binding IsSelected}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <MultiDataTrigger.Setters>
                                                                        <Setter Property="Background" Value="#2E7D32"/>
                                                                        <Setter Property="BorderBrush" Value="#1B5E20"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </MultiDataTrigger.Setters>
                                                                </MultiDataTrigger>

                                                                <!-- При наведении на свободное место -->
                                                                <MultiTrigger>
                                                                    <MultiTrigger.Conditions>
                                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                                        <Condition Property="IsEnabled" Value="True"/>
                                                                    </MultiTrigger.Conditions>
                                                                    <MultiTrigger.Setters>
                                                                        <Setter Property="BorderBrush" Value="#2E7D32"/>
                                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                                    </MultiTrigger.Setters>
                                                                </MultiTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20"
                    BorderBrush="#C8E6C9" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" 
                                     ShadowDepth="2" 
                                     Opacity="0.1" 
                                     Direction="270"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#E8F5E9"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Выбрано мест: " 
                                           FontSize="15" 
                                           Foreground="#1B5E20"/>
                                <TextBlock x:Name="SelectedCountTextBlock" 
                                           Text="0" 
                                           FontSize="16" 
                                           FontWeight="Bold" 
                                           Foreground="#2E7D32"
                                           Margin="3,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#E8F5E9"
                                CornerRadius="8"
                                Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Сумма: " 
                                           FontSize="15" 
                                           Foreground="#1B5E20"/>
                                <TextBlock x:Name="TotalPriceTextBlock" 
                                           Text="0 ₽" 
                                           FontSize="16" 
                                           FontWeight="Bold" 
                                           Foreground="#2E7D32"
                                           Margin="3,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1" 
                            x:Name="BookButton"
                            Content="Оформить билет" 
                            Click="BookButton_Click"
                            Background="#2E7D32" 
                            Foreground="White"
                            BorderThickness="0"
                            Padding="30,12"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            IsEnabled="False">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#A5D6A7"/>
                                        <Setter Property="Cursor" Value="Arrow"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>