<Window x:Class="Pr14.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pr14"
        mc:Ignorable="d"
        Title="Кинотеатр" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#E8F5E9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#1B5E20" 
                Padding="10,8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" 
                                  ShadowDepth="2" 
                                  Opacity="0.25" 
                                  Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <Button x:Name="BackButton" 
                            Content="← Назад" 
                            Background="#2E7D32"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="10,5"
                            Cursor="Hand"
                            Margin="0,0,15,0"
                            Visibility="Collapsed"
                            Click="BackButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock Text="🎬" 
                              FontSize="20" 
                              Foreground="#C8E6C9" 
                              Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                    <TextBlock x:Name="PageTitleTextBlock" 
                              Text="Главная страница" 
                              Foreground="#FFFFFF" 
                              FontSize="18" 
                              FontWeight="SemiBold"
                              FontFamily="Segoe UI"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" 
                           Orientation="Horizontal" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right">
                    <Border Background="#2E7D32" 
                            CornerRadius="15" 
                            Height="28" 
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="" 
                                      FontSize="14" 
                                      Foreground="#FFFFFF"
                                      Margin="0,0,5,0"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="UserInfoTextBlock" 
                                      Text="Гость" 
                                      Foreground="#FFFFFF" 
                                      VerticalAlignment="Center"
                                      FontSize="13"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="AuthButton" 
                            Content="Войти" 
                            Background="#43A047"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="12,5"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Margin="2,0"
                            Click="AuthButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4CAF50"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="ProfileButton" 
                            Content="Профиль" 
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="12,5"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Margin="2,0"
                            Visibility="Collapsed"
                            Click="ProfileButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="LogoutButton" 
                            Content="Выйти" 
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="12,5"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Margin="2,0,0,0"
                            Visibility="Collapsed"
                            Click="LogoutButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D32F2F"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Background="#E8F5E9"
                Padding="20"
                CornerRadius="20,0,0,0">
            <Frame x:Name="MainFrame" 
                   NavigationUIVisibility="Hidden"
                   Navigated="MainFrame_Navigated"/>
        </Border>
    </Grid>
</Window>